              "features/welcome-messages",
              "features/mod-logs",
              "features/mod-agreements",
              "features/bot-personalizer",
              "features/custom-bot",
              "features/custom-commands",
              "features/social-alerts",
              "features/leveling",
              "features/live-monitor",
              "features/live-tools",
              "features/channel-role-manager",
              "features/birthdays",
              "features/transcripts",
              "features/reports"
            ]
          },
          {
            "group": "Integrations",
            "pages": [
              "integrations/stream-deck",
              "integrations/api-logs"
